{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/anubissbe/ac-modding-kit/main/schemas/acmk-workshop-state-v1.schema.json",
  "title": "ACMK Workshop state v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "app_id",
    "status",
    "steam_mod_id",
    "visibility",
    "predecessor_ids",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "app_id": {"const": 667610},
    "status": {
      "enum": ["unpublished", "published", "deleted-predecessor"]
    },
    "steam_mod_id": {"$ref": "#/$defs/steamModId"},
    "visibility": {
      "enum": ["public", "friends-only", "private", "unlisted", "unknown"]
    },
    "predecessor_ids": {
      "type": "array",
      "maxItems": 1024,
      "uniqueItems": true,
      "items": {
        "allOf": [
          {"$ref": "#/$defs/steamModId"},
          {"not": {"const": "0,0"}}
        ]
      }
    },
    "last_verified_at": {
      "oneOf": [
        {"const": ""},
        {
          "type": "string",
          "format": "date-time",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"
        }
      ]
    }
  },
  "$defs": {
    "steamModId": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]{0,8}|[1-3][0-9]{9}|4[01][0-9]{8}|42[0-8][0-9]{7}|429[0-3][0-9]{6}|4294[0-8][0-9]{5}|42949[0-5][0-9]{4}|429496[0-6][0-9]{3}|4294967[01][0-9]{2}|42949672[0-8][0-9]|429496729[0-5]),(?:0|[1-9][0-9]{0,8}|[1-3][0-9]{9}|4[01][0-9]{8}|42[0-8][0-9]{7}|429[0-3][0-9]{6}|4294[0-8][0-9]{5}|42949[0-5][0-9]{4}|429496[0-6][0-9]{3}|4294967[01][0-9]{2}|42949672[0-8][0-9]|429496729[0-5])$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"status": {"const": "unpublished"}},
        "required": ["status"]
      },
      "then": {
        "properties": {"steam_mod_id": {"const": "0,0"}}
      },
      "else": {
        "properties": {"steam_mod_id": {"not": {"const": "0,0"}}}
      }
    }
  ]
}
