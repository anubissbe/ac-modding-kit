# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/

# Environments and local configuration
.venv*/
venv/
.env
.env.*
!.env.example
*.local.toml

# Editors and operating systems
.idea/
.vscode/
*.code-workspace
*.swp
Thumbs.db
.DS_Store

# Blender local state and recoverable backups
*.blend[0-9]*
*.blend@
modeling/.cache/
modeling/.staging/
modeling/build/

# Local reports and scratch output
artifacts/
coverage.xml
*.log
*.tmp
tests/.fixture-*/
tests/.tmp-*/

# Never commit local game, Workshop, or save data
game-assets/
local-mods/
steamapps/
vendor-game/
workshop-content/
*.sav
*.save
